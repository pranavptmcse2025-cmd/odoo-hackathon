# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/ecosphere?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:5173

# Integration — base URLs for teammates' modules (leave blank if same server/mounted routes)
ENV_MODULE_API_URL=http://localhost:5000/api
SOCIAL_MODULE_API_URL=http://localhost:5000/api
